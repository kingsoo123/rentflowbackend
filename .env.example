# Copy to .env and fill in values (never commit .env).
# Production (e.g. Render): see docs/render.md for the full checklist.

# --- Required ---
# Supabase → Project Settings → Database → URI, or Render Postgres "Internal/External Database URL"
# Must include database name in path (e.g. /postgres). URL-encode special chars in password.
# DATABASE_URL=postgresql://...

PORT=process.env.PORT || 3001
NODE_ENV=production

# Required in production (min 16 characters). Render blueprint can use generateValue: true.
# JWT_SECRET=

# --- CORS (recommended in production) ---
# Comma-separated origins for your frontend (Next.js, etc.)
# CORS_ORIGIN=http://localhost:3000

# --- Optional: TypeORM / Postgres ---
TYPEORM_LOGGING=true
# TYPEORM_SYNCHRONIZE=true   # dev only; never in production
# DATABASE_SSL=              # true | false | omit (omit = TLS for remote hosts)
# DATABASE_POOL_MAX=10
# DATABASE_RESOLVE_IPV4=false

# --- Optional: Resend (rent renewal email copy to tenant) ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=EstateFlow <onboarding@resend.dev>

# Copy to .env and fill in values (never commit .env).
# Production (e.g. Render): see docs/render.md for the full checklist.

# --- Required ---
# Supabase → Project Settings → Database → URI, or Render Postgres "Internal/External Database URL"
# Must include database name in path (e.g. /postgres). URL-encode special chars in password.
# DATABASE_URL=postgresql://...

PORT=3001
NODE_ENV=development

# Required in production (min 16 characters). Render blueprint can use generateValue: true.
# JWT_SECRET=

# --- CORS (recommended in production) ---
# Comma-separated origins for your frontend (Next.js, etc.)
# CORS_ORIGIN=http://localhost:3000

# --- Optional: TypeORM / Postgres ---
TYPEORM_LOGGING=true
# TYPEORM_SYNCHRONIZE=true   # dev only; never in production
# DATABASE_SSL=              # true | false | omit (omit = TLS for remote hosts)
# DATABASE_POOL_MAX=10
# DATABASE_RESOLVE_IPV4=false

# --- Optional: Resend (rent renewal email copy to tenant) ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=EstateFlow <onboarding@resend.dev>

# --- Optional: Firebase Cloud Messaging (Android device tokens from the mobile app) ---
# Use ONE of the following. Never commit real keys.
# Local file (path relative to real_estate_backend cwd or absolute):
# FIREBASE_SERVICE_ACCOUNT_PATH=./rentpilot-3c8e4-firebase-adminsdk-fbsvc-0a7f02c918.json
# Or Google’s standard (path to the same JSON file):
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Or for Render/hosting without a file: base64-encode the JSON and set:
# FIREBASE_SERVICE_ACCOUNT_BASE64=...
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}  # fragile in .env; prefer BASE64 or PATH

# --- Optional: Firebase Cloud Messaging (Android device tokens from mobile app) ---
# Base64-encode the Firebase service account JSON (single line for .env):
#   base64 -w0 service-account.json
# FIREBASE_SERVICE_ACCOUNT_BASE64=
# Or: GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

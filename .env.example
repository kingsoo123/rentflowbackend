# Copy to .env and fill in values (never commit .env).

# Supabase → Project Settings → Database → Connection string → URI
# Prefer "Transaction pooler" for server apps (port 6543) and append ?pgbouncer=true
# Example:
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

PORT=3001
NODE_ENV=development

# JWT for POST /api/auth/login (required in production: min 16 characters).
# JWT_SECRET=

# Optional — Resend (https://resend.com) sends a rent renewal copy to the tenant’s email when a manager delivers a notice.
# RESEND_API_KEY=re_xxxxxxxx
# Default from (must be allowed in Resend; use your verified domain in production):
# RESEND_FROM=EstateFlow <onboarding@resend.dev>
TYPEORM_LOGGING=true

# TLS: omit or true for Supabase; set false only for local Postgres without SSL.
DATABASE_SSL=

# Optional connection pool size (node-pg).
# DATABASE_POOL_MAX=10

# Resolve DB hostname to IPv4 before connecting (avoids ENETUNREACH when AAAA is used first).
# DATABASE_RESOLVE_IPV4=false

# Comma-separated browser origins for CORS (Next.js local dev example).
# CORS_ORIGIN=http://localhost:3000
